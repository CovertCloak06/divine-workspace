#!/bin/bash
# Nexus Terminal CLI - Direct command execution
# Usage: ncli <command> [args...]
# Example: ncli /pentest 192.168.1.1

set -e

NEXUS_URL="http://localhost:8010"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Check args BEFORE health check to avoid unnecessary 5-10s startup delay
# when user just wants help message (should be instant ~2ms)
# If no args, show help (don't auto-start Nexus just for help)
if [ $# -eq 0 ]; then
    echo -e "${CYAN}Nexus CLI${NC} - Terminal command interface"
    echo ""
    echo "Usage: ncli <command> [args...]"
    echo ""
    echo "Examples:"
    echo "  ncli /pentest 192.168.1.1"
    echo "  ncli /scan localhost"
    echo "  ncli /whois example.com"
    echo "  ncli /code write hello.py"
    echo ""
    echo "For all commands, see: nexus --help"
    exit 0
fi

# Check if Nexus is running, auto-start if not (only when user provides a command)
if ! curl -s "$NEXUS_URL/health" >/dev/null 2>&1; then
    echo -e "${YELLOW}⚠${NC}  Nexus not running, starting it now..."
    echo ""
    cd /home/gh0st/dvn/divine-workspace/apps/nexus
    ./nexus_control.sh start-all

    # Wait for services to be ready (max 5 seconds)
    echo ""
    echo -e "${CYAN}⏳${NC} Waiting for services to be ready..."
    for i in {1..5}; do
        if curl -s "$NEXUS_URL/health" >/dev/null 2>&1; then
            echo -e "${GREEN}✓${NC} Nexus ready!"
            break
        fi
        sleep 1
    done

    # Final check
    if ! curl -s "$NEXUS_URL/health" >/dev/null 2>&1; then
        echo -e "${RED}✗${NC} Failed to start Nexus"
        echo "Try manually: nexus-start"
        exit 1
    fi
    echo ""
fi

# Build the message from all arguments
MESSAGE="$*"

# Send to Nexus API
echo -e "${CYAN}→${NC} Sending: ${MESSAGE}"
echo ""

RESPONSE=$(curl -s -X POST "$NEXUS_URL/api/multi-agent/chat" \
    -H "Content-Type: application/json" \
    -d "{\"message\": \"$MESSAGE\", \"mode\": \"auto\"}" 2>&1)

# Check if response is valid JSON
if echo "$RESPONSE" | jq empty 2>/dev/null; then
    # Extract response text
    REPLY=$(echo "$RESPONSE" | jq -r '.response // .error // "No response"')
    AGENT=$(echo "$RESPONSE" | jq -r '.agent // "unknown"')
    
    echo -e "${GREEN}✓${NC} Response from ${CYAN}${AGENT}${NC}:"
    echo ""
    echo "$REPLY"
else
    echo -e "${RED}Error:${NC} Invalid response from Nexus"
    echo "$RESPONSE"
    exit 1
fi
