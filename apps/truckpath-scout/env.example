# TruckPath Scout environment variables — ALL OPTIONAL.
# Copy to `.env` to use. The MVP runs with zero configuration:
# OpenStreetMap tiles, Esri satellite imagery, and Nominatim geocoding are keyless.

# --- Optional AI instruction polish -------------------------------------
# Any OpenAI/Claude-compatible chat completions endpoint. When unset, the
# deterministic template generator is used (recommended for field use).
# VITE_AI_ENDPOINT=https://api.example.com/v1/chat/completions
# VITE_AI_API_KEY=sk-...
# VITE_AI_MODEL=claude-sonnet-5
