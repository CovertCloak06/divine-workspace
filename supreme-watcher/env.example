# Copy this file to ".env" and fill in your values:  cp env.example .env

# ─── Pushover (required) ─────────────────────────────────────────────────────
# 1. Create an account: https://pushover.net
# 2. Your "User Key" is on the dashboard home page.
# 3. Create an Application/API Token: https://pushover.net/apps/build
# 4. Install the Pushover app on the iPhone and log in with the same account.
PUSHOVER_TOKEN=your_application_api_token
PUSHOVER_USER=your_user_key

# ─── Source ──────────────────────────────────────────────────────────────────
# US store: https://www.supremenewyork.com
# EU store: https://uk.supremenewyork.com
SUPREME_BASE_URL=https://www.supremenewyork.com

# ─── Polling ─────────────────────────────────────────────────────────────────
# Base interval between checks, in milliseconds. Be polite; 60000 (60s) is sane.
POLL_INTERVAL_MS=60000
# Random extra wait (0..JITTER_MS) added each cycle so the pattern isn't robotic.
JITTER_MS=15000

# ─── Filters (all optional; leave blank to alert on everything) ──────────────
# Comma-separated, case-insensitive substrings matched against the item name.
#   e.g. WATCH_KEYWORDS=box logo,tee,hoodie
WATCH_KEYWORDS=
# Comma-separated Supreme category names.
#   e.g. WATCH_CATEGORIES=Jackets,Sweatshirts,Tops/Sweaters,Accessories
WATCH_CATEGORIES=
# Only alert at or below this price in USD. Blank = no cap.
MAX_PRICE=

# ─── Alert behavior ──────────────────────────────────────────────────────────
# Alert when a previously sold-out item comes back in stock.
ALERT_ON_RESTOCK=true
# Alert when a watched item's price drops.
ALERT_ON_PRICE_DROP=false
# Log matches without sending notifications (for testing).
DRY_RUN=false

# ─── Internals ───────────────────────────────────────────────────────────────
# Where to persist seen-item state so you aren't re-alerted on every cycle.
STORE_PATH=./data/state.json
