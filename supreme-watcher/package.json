{
  "name": "supreme-watcher",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Monitors supremenewyork.com for new items and restocks, sending real-time Pushover alerts.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx --test tests/*.test.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["supreme", "monitor", "restock", "drop", "pushover", "alerts"],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
